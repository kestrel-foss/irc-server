OVERNET_IRC_ADAPTER_ID=irc.public
OVERNET_IRC_NETWORK=overnet
OVERNET_IRC_LISTEN_HOST=0.0.0.0
OVERNET_IRC_LISTEN_PORT=16667
OVERNET_IRC_SERVER_NAME=irc.overnet.net
OVERNET_IRC_SIGNING_KEY_FILE=/var/lib/overnet/irc/signing-key.pem
OVERNET_IRC_GROUP_HOST=groups.overnet.net
OVERNET_IRC_AUTHORITY_RELAY_URL=ws://127.0.0.1:7447
OVERNET_IRC_TLS_CERT_CHAIN_FILE=/etc/overnet/tls/fullchain.pem
OVERNET_IRC_TLS_PRIVATE_KEY_FILE=/etc/overnet/tls/privkey.pem
OVERNET_IRC_LOG_FILE=/var/log/overnet/irc.log
OVERNET_IRC_HEALTH_FILE=/run/overnet/irc-health.json
